---
import Layout from "../../layouts/Layout.astro";
import { getEntry, render, getCollection } from "astro:content";
import { Image } from "astro:assets";
import { identity } from "../../config";
import FixedRotatedTitle from "../../components/FixedRotatedTitle.astro";
import ArchivedPostCallout from "../../components/ArchivedPostCallout.astro";
import ArchivedPostStyles from "../../components/ArchivedPostStyles.astro";
import { isArchivedPost } from "../../utils/post-age";

export async function getStaticPaths() {
    const posts = await getCollection("posts", ({ data }) => {
        return data.draft !== true;
    });

    return posts.map((post) => ({
        params: { id: post.id },
    }));
}

const { id } = Astro.params;
const entry = await getEntry("posts", id as string);

if (!entry) {
    return Astro.redirect("/blog");
}

const { Content, remarkPluginFrontmatter } = await render(entry);
const isArchived = isArchivedPost(entry.data.date);
---

<Layout
    seo={{
        title: entry.data.title,
        description: entry.data.description || entry.data.title,
        image: entry.data.banner || identity.logo,
        imageWidth: entry.data.banner ? 1200 : undefined,
        imageHeight: entry.data.banner ? 630 : undefined,
    }}
>
    {isArchived && (
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
        />
    )}
    {isArchived && <ArchivedPostStyles />}

    <FixedRotatedTitle title="Blog" />

    <section class="mt-10 max-w-3xl mx-auto px-6 md:pl-20">
        <div class:list={[{ "archived-post": isArchived }]}>
            <h1
                class:list={[
                    "font-bold text-3xl mb-4",
                    { "archived-title": isArchived },
                ]}
            >
                {entry.data.title}
            </h1>
            {
                entry.data.description && (
                    <p
                        class:list={[
                            "opacity-60 mb-6",
                            { "archived-muted": isArchived },
                        ]}
                    >
                        {entry.data.description}
                    </p>
                )
            }
            <div class="flex gap-4 mb-6">
                <Image
                    src={identity.logo}
                    alt={identity.name}
                    width={40}
                    height={40}
                    class:list={[
                        "w-[40px] aspect-square object-cover rounded-full",
                        isArchived && "ring-1 ring-[rgba(58,50,40,0.2)]",
                    ]}
                />
                <div>
                    <p
                        class:list={[
                            "font-medium",
                            { "archived-meta-name": isArchived },
                        ]}
                    >
                        {identity.name}
                    </p>
                    <p
                        class:list={[
                            "opacity-60",
                            { "archived-muted": isArchived },
                        ]}
                    >
                        {entry.data.date.toLocaleDateString()} · {
                            remarkPluginFrontmatter.minutesRead
                        }
                    </p>
                </div>
            </div>

            {
                entry.data.banner && (
                    <div
                        class:list={[
                            "relative h-56 sm:h-64 md:h-72 overflow-hidden mb-8",
                            { "archived-banner-wrap": isArchived },
                        ]}
                    >
                        <img
                            src={entry.data.banner}
                            alt=""
                            class="w-full h-full object-cover object-center"
                        />
                        {!isArchived && (
                            <>
                                <div class="absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-black to-transparent pointer-events-none" />
                                <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-b from-transparent to-black pointer-events-none" />
                            </>
                        )}
                        {entry.data.bannerAttribution && (
                            <p
                                class:list={[
                                    "absolute bottom-2 right-3 text-[11px] opacity-50 hover:opacity-90 transition-opacity",
                                    {
                                        "archived-banner-attribution":
                                            isArchived,
                                    },
                                ]}
                            >
                                {entry.data.bannerAttributionUrl ? (
                                    <a
                                        href={entry.data.bannerAttributionUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                        {entry.data.bannerAttribution}
                                    </a>
                                ) : (
                                    entry.data.bannerAttribution
                                )}
                            </p>
                        )}
                    </div>
                )
            }

            {isArchived && <ArchivedPostCallout date={entry.data.date} />}

            <article
                class:list={[
                    "prose prose-a:underline-offset-4 prose-headings:mb-2",
                    isArchived
                        ? "archived-prose prose-lg max-w-none"
                        : "prose-invert prose-a:text-blue-300 prose-p:text-[#e5e5e5]",
                ]}
            >
                <Content />
            </article>
        </div>
    </section>
</Layout>
