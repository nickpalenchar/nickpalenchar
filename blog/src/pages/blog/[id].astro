---
import Layout from "../../layouts/Layout.astro";
import { getEntry, render, getCollection } from "astro:content";
import { Image } from "astro:assets";
import { identity } from "../../config";
import FixedRotatedTitle from "../../components/FixedRotatedTitle.astro";

export async function getStaticPaths() {
    const posts = await getCollection("posts", ({ data }) => {
        return data.draft !== true;
    });

    return posts.map((post) => ({
        params: { id: post.id },
    }));
}

const { id } = Astro.params;
const entry = await getEntry("posts", id as string);

if (!entry) {
    return Astro.redirect("/blog");
}

const { Content, remarkPluginFrontmatter } = await render(entry);
---

<Layout
    seo={{
        title: entry.data.title,
        description: entry.data.description || entry.data.title,
        image: entry.data.banner || identity.logo,
        imageWidth: entry.data.banner ? 1200 : undefined,
        imageHeight: entry.data.banner ? 630 : undefined,
    }}
>
    <!-- Fixed rotated title -->
    <FixedRotatedTitle title="Blog" />

    <section class="mt-10 max-w-3xl mx-auto px-6 md:pl-20">
        <h1 class="font-bold text-3xl mb-4">{entry.data.title}</h1>
        {
            entry.data.description && (
                <p class="opacity-60 mb-6">{entry.data.description}</p>
            )
        }
        <div class="flex gap-4 mb-6">
            <Image
                src={identity.logo}
                alt={identity.name}
                width={40}
                height={40}
                class="w-[40px] aspect-square object-cover rounded-full"
            />
            <div>
                <p class="font-medium">{identity.name}</p>
                <p class="opacity-60">
                    {entry.data.date.toLocaleDateString()} · {
                        remarkPluginFrontmatter.minutesRead
                    }
                </p>
            </div>
        </div>

        {entry.data.banner && (
            <div class="relative h-56 sm:h-64 md:h-72 overflow-hidden mb-8">
                <img
                    src={entry.data.banner}
                    alt=""
                    class="w-full h-full object-cover object-center"
                />
                <div class="absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-black to-transparent pointer-events-none" />
                <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-b from-transparent to-black pointer-events-none" />
                {entry.data.bannerAttribution && (
                    <p class="absolute bottom-2 right-3 text-[11px] opacity-50 hover:opacity-90 transition-opacity">
                        {entry.data.bannerAttributionUrl ? (
                            <a href={entry.data.bannerAttributionUrl} target="_blank" rel="noopener noreferrer">
                                {entry.data.bannerAttribution}
                            </a>
                        ) : (
                            entry.data.bannerAttribution
                        )}
                    </p>
                )}
            </div>
        )}

        <article
            class="prose prose-invert prose-a:text-blue-300 prose-a:underline-offset-4 prose-headings:mb-2 prose-p:text-[#e5e5e5]"
        >
            <Content />
        </article>
    </section>
</Layout>
