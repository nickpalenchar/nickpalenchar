---
import Layout from "../../layouts/Layout.astro";
import { getEntry, render, getCollection } from "astro:content";
import { Image } from "astro:assets";
import { identity } from "../../config";
import FixedRotatedTitle from "../../components/FixedRotatedTitle.astro";
import ArchivedPostCallout from "../../components/ArchivedPostCallout.astro";
import LibraryReadingStyles from "../../components/LibraryReadingStyles.astro";
import { isArchivedPost } from "../../utils/post-age";

export async function getStaticPaths() {
    const posts = await getCollection("posts", ({ data }) => {
        return data.draft !== true;
    });

    return posts.map((post) => ({
        params: { id: post.id },
    }));
}

const { id } = Astro.params;
const entry = await getEntry("posts", id as string);

if (!entry) {
    return Astro.redirect("/blog");
}

const { Content, remarkPluginFrontmatter } = await render(entry);
const isArchived = isArchivedPost(entry.data.date);
---

<Layout
    seo={{
        title: entry.data.title,
        description: entry.data.description || entry.data.title,
        image: entry.data.bannerOg || entry.data.banner || identity.logo,
        imageWidth: entry.data.banner ? 1200 : undefined,
        imageHeight: entry.data.banner ? 630 : undefined,
    }}
>
    <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
    />
    <LibraryReadingStyles />

    <FixedRotatedTitle title="Blog" />

    <section class="mt-10 w-full max-w-4xl mx-auto px-0 sm:px-6 md:pl-20">
        <div class="library-reading">
            <h1 class="library-title font-bold text-3xl mb-4">
                {entry.data.title}
            </h1>
            {
                entry.data.description && (
                    <p class="library-muted opacity-60 mb-6">
                        {entry.data.description}
                    </p>
                )
            }
            <div class="flex gap-4 mb-6">
                <Image
                    src={identity.logo}
                    alt={identity.name}
                    width={40}
                    height={40}
                    class="w-[40px] aspect-square object-cover rounded-full ring-1 ring-[rgba(58,50,40,0.2)]"
                />
                <div>
                    <p class="library-meta-name font-medium">{identity.name}</p>
                    <p class="library-muted opacity-60">
                        {entry.data.date.toLocaleDateString()} · {
                            remarkPluginFrontmatter.minutesRead
                        }
                    </p>
                </div>
            </div>

            {
                entry.data.banner && (
                    <div class="library-banner-wrap relative h-56 sm:h-64 md:h-72 overflow-hidden mb-8">
                        <img
                            src={entry.data.banner}
                            alt=""
                            class="w-full h-full object-cover object-center"
                        />
                        {entry.data.bannerAttribution && (
                            <p class="library-banner-attribution absolute bottom-2 right-3 text-[11px] opacity-50 hover:opacity-90 transition-opacity">
                                {entry.data.bannerAttributionUrl ? (
                                    <a
                                        href={entry.data.bannerAttributionUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                        {entry.data.bannerAttribution}
                                    </a>
                                ) : (
                                    entry.data.bannerAttribution
                                )}
                            </p>
                        )}
                    </div>
                )
            }

            {isArchived && <ArchivedPostCallout date={entry.data.date} />}

            <article
                class="library-prose prose max-w-none prose-a:underline-offset-4 prose-headings:mb-2"
            >
                <Content />
            </article>
        </div>
    </section>
</Layout>
