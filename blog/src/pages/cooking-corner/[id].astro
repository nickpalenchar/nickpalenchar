---
import Layout from "../../layouts/Layout.astro";
import { getEntry, render, getCollection } from "astro:content";
import { Image } from "astro:assets";
import { identity } from "../../config";
import FixedRotatedTitle from "../../components/FixedRotatedTitle.astro";

export async function getStaticPaths() {
  const entries = await getCollection("posts", ({ data }) => {
    return (
      data.draft !== true &&
      (data.tags || []).includes("collection/cooking-corner")
    );
  });

  return entries.map((entry) => ({
    params: { id: entry.id },
  }));
}

const { id } = Astro.params;
const entry = await getEntry("posts", id as string);

if (!entry) {
  return Astro.redirect("/cooking-corner");
}

const { Content, remarkPluginFrontmatter } = await render(entry);
---

<Layout
  seo={{
    title: entry.data.title,
    description: entry.data.description || entry.data.title,
    image: identity.logo,
  }}
>
  <FixedRotatedTitle title="Cooking Corner" />

  <section class="mt-10 max-w-3xl mx-auto px-6 md:pl-20">
    <h1 class="font-bold text-3xl mb-4 text-amber-100">
      {entry.data.title}
    </h1>
    {
      entry.data.description && (
        <p class="opacity-80 mb-6 text-amber-100">
          {entry.data.description}
        </p>
      )
    }
    <div class="flex gap-4 mb-6">
      <Image
        src={identity.logo}
        alt={identity.name}
        width={40}
        height={40}
        class="w-[40px] aspect-square object-cover rounded-full"
      />
      <div>
        <p class="font-medium text-amber-100">{identity.name}</p>
        <p class="opacity-70 text-amber-100">
          {entry.data.date.toLocaleDateString()} ·{" "}
          {remarkPluginFrontmatter.minutesRead}
        </p>
      </div>
    </div>

    <article
      class="prose prose-invert cooking-prose prose-a:text-amber-200 prose-a:underline-offset-4 prose-headings:mb-2 prose-p:text-[#f5f5f5]"
    >
      <Content />
    </article>
  </section>
</Layout>

