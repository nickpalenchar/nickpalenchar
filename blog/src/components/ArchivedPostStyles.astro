<style is:global>
    .archived-post {
        font-family: "Libre Baskerville", Georgia, "Times New Roman", serif;
        color: #3a3228;
        background: linear-gradient(
                165deg,
                #faf6ec 0%,
                #f0e6d0 42%,
                #e8dcc4 100%
            ),
            repeating-linear-gradient(
                90deg,
                transparent,
                transparent 2px,
                rgba(58, 50, 40, 0.015) 2px,
                rgba(58, 50, 40, 0.015) 3px
            );
        border: 1px solid rgba(58, 50, 40, 0.22);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.55),
            0 2px 4px rgba(0, 0, 0, 0.35),
            0 12px 40px rgba(0, 0, 0, 0.45);
        padding: 2rem 1.75rem 2.5rem;
        margin: 0 -0.5rem;
    }

    @media (min-width: 640px) {
        .archived-post {
            padding: 2.5rem 2.25rem 3rem;
            margin: 0;
        }
    }

    .archived-post * {
        color: inherit;
    }

    .archived-post .archived-title {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-weight: 700;
        letter-spacing: 0.01em;
        color: #2a241c;
    }

    .archived-post .archived-muted {
        color: rgba(58, 50, 40, 0.72);
    }

    .archived-post .archived-meta-name {
        font-weight: 600;
        color: #2a241c;
    }

    .archived-callout {
        border: 1px solid rgba(58, 50, 40, 0.28);
        border-left: 3px solid #8b7355;
        background: rgba(255, 252, 245, 0.65);
        padding: 1rem 1.15rem;
        margin-bottom: 2rem;
    }

    .archived-callout-label {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #6b5a45;
        margin-bottom: 0.45rem;
    }

    .archived-callout-body {
        font-size: 0.95rem;
        line-height: 1.65;
        color: #3a3228;
    }

    .archived-callout-body strong {
        font-weight: 700;
        color: #2a241c;
    }

    .archived-post .archived-banner-wrap {
        border: 1px solid rgba(58, 50, 40, 0.18);
        margin-bottom: 1.75rem;
    }

    .archived-post .archived-banner-wrap img {
        filter: sepia(0.35) saturate(0.85) contrast(0.95);
    }

    .archived-post .archived-banner-attribution {
        color: rgba(58, 50, 40, 0.55);
    }

    .archived-post .archived-banner-attribution a {
        color: rgba(58, 50, 40, 0.7);
    }

    .archived-post .archived-banner-attribution a:hover {
        color: #2a241c;
    }

    .archived-prose {
        --tw-prose-body: #3a3228;
        --tw-prose-headings: #2a241c;
        --tw-prose-lead: #4a4034;
        --tw-prose-links: #5c4a32;
        --tw-prose-bold: #2a241c;
        --tw-prose-counters: #6b5a45;
        --tw-prose-bullets: #8b7355;
        --tw-prose-hr: rgba(58, 50, 40, 0.25);
        --tw-prose-quotes: #4a4034;
        --tw-prose-quote-borders: #8b7355;
        --tw-prose-captions: #6b5a45;
        --tw-prose-code: #2a241c;
        --tw-prose-pre-code: #e8dcc4;
        --tw-prose-pre-bg: #2a241c;
        --tw-prose-th-borders: rgba(58, 50, 40, 0.25);
        --tw-prose-td-borders: rgba(58, 50, 40, 0.18);
        font-family: "Libre Baskerville", Georgia, serif;
        font-size: 1.05rem;
        line-height: 1.75;
    }

    .archived-prose :where(h1, h2, h3, h4):not(:where([class~="not-prose"] *)) {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-weight: 700;
    }

    .archived-prose :where(a):not(:where([class~="not-prose"] *)) {
        color: #5c4a32;
        text-decoration-color: rgba(92, 74, 50, 0.45);
    }

    .archived-prose :where(a:hover):not(:where([class~="not-prose"] *)) {
        color: #2a241c;
    }

    .archived-prose :where(code):not(:where([class~="not-prose"] *)) {
        background: rgba(58, 50, 40, 0.08);
        padding: 0.12em 0.35em;
        border-radius: 2px;
        font-size: 0.88em;
    }

    .archived-prose :where(blockquote):not(:where([class~="not-prose"] *)) {
        border-left-color: #8b7355;
        font-style: italic;
        color: #4a4034;
    }

    .archived-prose table th,
    .archived-prose table td {
        border-color: rgba(58, 50, 40, 0.2);
    }
</style>
